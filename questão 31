programa {
	funcao inicio() {
		real fatorial = 1.0 , E = 1.0
		inteiro termos
		
		escreva("Calculando os sucessivos valores de E \n\n")
		
		para (inteiro i = 1; i <= 4; i++)
		{
			fatorial = fatorial * i
			
			E = E + (1.0 / fatorial)
			
			termos = i + 1

			se (termos == 3 ou termos == 4 ou termos == 5)
			{
				escreva("Com ", termos, " termos, E = ", E, "\n")
			}
		}
	}
}
